rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Avaliações publicadas para os pais.
    // O ID do documento é um token aleatório (difícil de adivinhar).
    match /avaliacoes/{token} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['student', 'eval', 'config'])
        && request.resource.data.student.keys().hasAll(['nome'])
        && request.resource.data.eval.keys().hasAll(['data']);
      allow update: if request.auth != null
        && resource.data.publisherUid == request.auth.uid;
      allow delete: if false;
    }
  }
}
